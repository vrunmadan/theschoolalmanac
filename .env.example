# Copy to .env.local and fill in. The app runs WITHOUT these (directory works,
# reviews show "Building") so you can deploy the directory first and add reviews later.

# Supabase (Stage 2 — reviews & scores)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Notion (optional Stage 1 CMS; the app falls back to data/schools.json if unset)
NOTION_TOKEN=
NOTION_DATA_SOURCE_ID=627ff4b5-c1f7-46db-918a-f1216941638e
